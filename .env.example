# Copy to .env and adjust. Never commit .env.

NODE_ENV=development
PORT=3000
HOST=0.0.0.0

# PostgreSQL connection string (Neon, Supabase, local Docker, etc.)
DATABASE_URL=postgresql://user:password@localhost:5432/elevate

# Min 32 chars in production — use `openssl rand -hex 32`
JWT_SECRET=change-me-use-at-least-32-characters-long-secret-here

# Access token lifetime (e.g. 15m, 1h)
JWT_ACCESS_EXPIRES_IN=15m

# Min 16 chars — used when hashing publishable site keys (pepper)
SITE_KEY_PEPPER=change-me-16chars-min

# Comma-separated browser origins allowed for CORS (admin + known marketing origins).
# Use * only for local experimentation. In NODE_ENV=production, * is rejected — list every origin.
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# Trust X-Forwarded-* from reverse proxy (set true behind Render/Railway/nginx/Cloudflare).
TRUST_PROXY=false

# Per-IP rate limits for POST /v1/auth/login and POST /v1/super-admin/auth/login
AUTH_LOGIN_RATE_MAX=20
AUTH_LOGIN_RATE_WINDOW_MS=60000

# In production, GET /v1/openapi.json returns 404 unless you set this to true (intentional public spec).
OPENAPI_PUBLIC_IN_PRODUCTION=false

# Public lead submission rate limit (in-memory; resets on multi-instance deploy)
RATE_LIMIT_MAX=60
RATE_LIMIT_WINDOW_MS=60000

# --- Optional: Cloudinary (direct uploads from admin UI / signed params) ---
# Set all three, or leave all unset. Get values from Cloudinary Dashboard → Settings → Product environment credentials.
# CLOUDINARY_CLOUD_NAME=
# CLOUDINARY_API_KEY=
# CLOUDINARY_API_SECRET=

# --- Optional: Resend (transactional email; test endpoint for org_admin) ---
# Get API key from https://resend.com — add & verify a domain for production "from" addresses.
# RESEND_API_KEY=re_xxxx
# RESEND_FROM=Your App <notifications@yourdomain.com>

# Super admin API + console (separate JWT; min 32 chars)
SUPER_ADMIN_JWT_SECRET=change-me-super-admin-jwt-32-chars-minimum-here
SUPER_ADMIN_ACCESS_EXPIRES_IN=8h
# Optional: create first super admin when DB table is empty (remove after use)
# SUPER_ADMIN_BOOTSTRAP_EMAIL=you@example.com
# SUPER_ADMIN_BOOTSTRAP_PASSWORD=12chars-min-secure
# Optional: restrict /v1/super-admin/* by client IP (comma-separated)
# SUPER_ADMIN_ALLOWED_IPS=
